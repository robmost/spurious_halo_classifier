# spurious_halo_classifier.mplstyle
# Based on cohare_palatino_sty.mplstyle (C. O'Hare).
# Modifications: font.size corrected to match axes.titlesize; minor ticks
# enabled; accessible colour palette (deuteranopia-safe); savefig defaults added.

# ---------------------------------------------------------------------------
# Figure
# ---------------------------------------------------------------------------
figure.figsize : 6, 6
figure.dpi : 140

# ---------------------------------------------------------------------------
# X axis
# ---------------------------------------------------------------------------
xtick.major.size    : 7.5
xtick.major.width   : 2
xtick.minor.size    : 5.5
xtick.minor.width   : 1
xtick.minor.visible : True
xtick.direction     : in
xtick.top           : True
xtick.labelsize     : 10
xtick.major.pad     : 9

# ---------------------------------------------------------------------------
# Y axis
# ---------------------------------------------------------------------------
ytick.major.size    : 7.5
ytick.major.width   : 2
ytick.minor.size    : 5.5
ytick.minor.width   : 1
ytick.minor.visible : True
ytick.direction     : in
ytick.right         : True
ytick.labelsize     : 10

# ---------------------------------------------------------------------------
# Font
# NOTE: text.usetex requires a LaTeX installation. Set to False if running
# in an environment without LaTeX (e.g. CI, bare notebooks).
# ---------------------------------------------------------------------------
font.family  : serif
font.serif   : Palatino
font.size    : 12.0
text.usetex  : True

# ---------------------------------------------------------------------------
# Axes
# ---------------------------------------------------------------------------
axes.linewidth  : 2.5
axes.titlesize  : 12
axes.labelsize  : 10

# ---------------------------------------------------------------------------
# Lines
# ---------------------------------------------------------------------------
lines.linewidth       : 2
lines.solid_capstyle  : round

# ---------------------------------------------------------------------------
# Grid
# ---------------------------------------------------------------------------
grid.linewidth : 1

# ---------------------------------------------------------------------------
# Legend
# ---------------------------------------------------------------------------
legend.frameon          : False
legend.fontsize         : 8
legend.title_fontsize   : 12

# ---------------------------------------------------------------------------
# Saving
# ---------------------------------------------------------------------------
savefig.dpi  : 200
savefig.bbox : tight

# ---------------------------------------------------------------------------
# Colour cycle — deuteranopia-safe, preserving the original palette character.
# Order: blue, green, orange, red, purple, dark grey, light grey.
# Swap: 00B945 (saturated green) -> 009E73 (muted teal-green, Wong palette).
#       FF2C00 (bright red) -> D55E00 (vermillion, distinguishable from green
#       under deuteranopia).
# Blue and orange kept in positions 1 and 3 to match CDM/WDM colouring from
# the paper (blue = CDM, red/orange = WDM).
# ---------------------------------------------------------------------------
axes.prop_cycle : cycler('color', ['0C5DA5', '009E73', 'FF9500', 'D55E00', '845B97', '474747', '9e9e9e'])
