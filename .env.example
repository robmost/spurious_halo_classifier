# Copy this file to .env and fill in your values. Never commit .env.
#
# Required for matplotlib LaTeX rendering in notebooks.
# Set to the bin directory of your full TeXLive installation, e.g.:
#   macOS (Homebrew): /opt/homebrew/Cellar/texlive/<year>/bin
#   Linux:            /usr/share/texlive/bin/x86_64-linux
# Leave unset to skip LaTeX rendering (plots will use mathtext instead).
LATEX_BIN_DIR=/path/to/your/texlive/installation
#
# Required for scripts/run_mergertree_analysis.sh:
MTREEBINPATH=/path/to/your/ahf/bin/MergerTree
